{
  "name": "mousemerchant",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Secure, dockerized MouseMerchant for monitoring MAM points and buying bonus upload credit.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist && cp -r public dist/public",
    "start": "node dist/index.js",
    "test": "vitest run tests"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "fastify": "^5.6.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
